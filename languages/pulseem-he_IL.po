msgstr "הגדרות זמן"

msgid "Add customers to group after:"
msgstr "הוספת לקוחות לקבוצה לאחר:"

msgid "Minutes"
msgstr "דקות"

msgid "Hours"
msgstr "שעות"

msgid "Days"
msgstr "ימים"

msgid "This time setting applies to both regular abandoned carts and \"Pending Payment\" orders (when enabled above)."
msgstr "הגדרת זמן זו חלה גם על עגלות נטושות רגילות וגם על הזמנות \"ממתינות לתשלום\" (כאשר האפשרות מופעלת למעלה)."

msgid "Product Synchronization"
msgstr "סנכרון מוצרים"

msgid "Enable Product Synchronization"
msgstr "הפעלת סנכרון מוצרים"

msgid "View all synchronized products in the JSON file. Use the sync button to update existing products and add new ones from your store. Products already in the system will only be updated, not duplicated."
msgstr "צפייה בכל המוצרים המסונכרנים בקובץ ה-JSON. ניתן להשתמש בכפתור הסנכרון כדי לעדכן מוצרים קיימים ולהוסיף חדשים מהחנות. מוצרים שכבר קיימים במערכת יעודכנו בלבד ולא ישוכפלו."

msgid "View Products List"
msgstr "צפייה ברשימת מוצרים"

msgid "Sync Store Products"
msgstr "סנכרון מוצרי חנות"

msgid "Page Tracking Settings"
msgstr "הגדרות מעקב עמודים"

msgid "Enable General Page Tracking"
msgstr "הפעלת מעקב עמודים כללי"

msgid "Track customer activities on general website pages."
msgstr "מעקב אחר פעילות לקוחות בעמודים כלליים באתר."

msgid "Enable WooCommerce Page Tracking"
msgstr "הפעלת מעקב עמודי WooCommerce"

msgid "Track customer activities specifically on WooCommerce pages like product, cart, and checkout pages."
msgstr "מעקב אחר פעילות לקוחות בעמודי WooCommerce כגון עמודי מוצר, עגלה וקופה."

msgid "Enable these options to monitor which pages customers are visiting. This helps in analyzing customer behavior and improving engagement."
msgstr "יש להפעיל אפשרויות אלה כדי לעקוב אחר העמודים שבהם לקוחות מבקרים. מידע זה מסייע בניתוח התנהגות לקוחות ושיפור מעורבות."

msgid "Video Tutorial"
msgstr "מדריך וידאו"

msgid "Learn how to install and set up Pulseem integration with this comprehensive video guide."
msgstr "מדריך וידאו מקיף להתקנה והגדרה של אינטגרציית פולסים."

msgid "Plugin Installation Guide"
msgstr "מדריך התקנת התוסף"

msgid "Complete step-by-step guide for installing and setting up the Pulseem WooCommerce integration plugin."
msgstr "מדריך מלא צעד אחר צעד להתקנה והגדרה של תוסף אינטגרציית פולסים ל-WooCommerce."

msgid "Setup Guide"
msgstr "מדריך הגדרה"

msgid "Duration: 3:45"
msgstr "משך: 3:45"

msgid "Update Settings"
msgstr "עדכון הגדרות"

msgid "Settings have been successfully updated."
msgstr "ההגדרות עודכנו בהצלחה."

msgid "Products synchronized successfully!"
msgstr "המוצרים סונכרנו בהצלחה!"

msgid "Error occurred during synchronization."
msgstr "אירעה שגיאה במהלך הסנכרון."

msgid "Synchronization in Progress"
msgstr "סנכרון בתהליך"

msgid "Updating existing products and adding new ones..."
msgstr "מתבצע עדכון מוצרים קיימים והוספת חדשים..."


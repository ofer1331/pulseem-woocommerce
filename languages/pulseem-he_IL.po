msgstr "לא נבחר"

msgid "New Purchase Settings"
msgstr "הגדרות רכישה חדשה"

msgid "Enable Purchase Tracking"
msgstr "הפעלת מעקב רכישות"

msgid "Track customer purchases and sync with Pulseem"
msgstr "מעקב אחר רכישות לקוחות וסנכרון עם פולסים"

msgid "Checkout Agreement"
msgstr "הסכמה בקופה"

msgid "Cart Abandonment Settings"
msgstr "הגדרות נטישת עגלה"

msgid "Enable Cart Abandonment Tracking"
msgstr "הפעלת מעקב נטישת עגלה"


msgstr "הכנסת לקוחות שלא אישרו הרשמה בסטטוס \"ממתין\""

msgid "Recipients in \"Pending\" will be receiving an Email asking them to Opt-In Until they Opt In, they will not receive any Emails or SMS messages."
msgstr "נמענים בסטטוס \"ממתין\" יקבלו אימייל עם בקשה לאישור הרשמה. עד לאישור, לא יישלחו אליהם הודעות אימייל או SMS."

msgid "Agreement Settings"
msgstr "הגדרות הסכמה"

msgid "Add a checkbox to your signup/checkout form to collect customer consent."
msgstr "הוספת תיבת סימון לטופס ההרשמה/התשלום לצורך איסוף הסכמת לקוחות."

msgid "Agreement Text"
msgstr "טקסט הסכמה"

